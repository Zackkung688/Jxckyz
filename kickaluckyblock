)

local function getChar()  return LP.Character end
local function getRoot()
    local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart")
end

local function tpTo(cf)
    local root = getRoot()
    if root then root.CFrame = cf + Vector3.new(0, 3, 0) end
end

local function findMyPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for i = 1, 5 do
        local plot = plots:FindFirstChild("Plot"..i)
        if plot then
            local spawn = plot:FindFirstChild("SpawnPart")
            if spawn and spawn:FindFirstChild("HomeIcon") then
                return plot
            end
        end
    end
end

local function getSlotPart(plot, slotName)
    local b = plot and plot:FindFirstChild("Buttons")
    return b and b:FindFirstChild(slotName)
end

local function fireCollect()
    for i = 1, 30 do
        pcall(function() net.rev_B_Collect:FireServer(i) end)
    end
end

local function fireUpgrade()
    for i = 1, 30 do
        pcall(function() net.rev_B_Upgrade:FireServer(i) end)
    end
end

local function equipDumbbell()
    pcall(function()
        local tool = LP.Backpack:FindFirstChild("Giant Gold Star Barbell")
                  or (LP.Character and LP.Character:FindFirstChild("Giant Gold Star Barbell"))
        if tool and LP.Character then
            LP.Character:FindFirstChildOfClass("Humanoid"):EquipTool(tool)
        end
    end)
end


