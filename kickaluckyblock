--  SKILL MANAGEMENT
-- ════════════════════════════════════════════════

local Flags = {
    Farm        = false,
    Collect     = false,
    Upgrade     = false,
    WeightTrain = false,
    SpeedUpgrade= false,
    WalkSpeed   = 55,
}

local _walkRunning   = false
local _walkTargetIdx = 1
local _walkSlots     = { "Slot3", "Slot13", "Slot23" }

local Skills = {}

task.spawn(function()
    while true do
        local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Jump = true end
        task.wait(60)
    end
end)

function Skills.Farm()
    task.spawn(function()
        while Flags.Farm do
            pcall(function()
                net.rev_KickEvent:FireServer(1)
                task.wait(0.1)
                net.rev_Transformed:FireServer()
            end)
            task.wait(0.2)
        end
    end)
end

function Skills.WalkLoop()
    if _walkRunning then return end
    _walkRunning = true
    task.spawn(function()
        while Flags.Collect or Flags.Upgrade do
            local plot    = findMyPlot()
            if not plot then task.wait(1); continue end

            local slotPart = getSlotPart(plot, _walkSlots[_walkTargetIdx])
            if slotPart then
                tpTo(slotPart.CFrame)
                task.wait(0.15)

                local root = getRoot()
                if root then
                    local t0  = tick()
                    local dst = slotPart.Position
                    while (root.Position - dst).Magnitude > 3 and tick() - t0 < 4 do
                        root.CFrame = root.CFrame + (dst - root.Position).Unit * Flags.WalkSpeed * 0.05
                        task.wait(0.05)
                    end
                end

                task.wait(0.1)
                if Flags.Collect then fireCollect() end
                if Flags.Upgrade  then fireUpgrade() end
                task.wait(0.2)
            end

            _walkTargetIdx = (_walkTargetIdx % #_walkSlots) + 1
            task.wait(0.15)
        end
        _walkRunning   = false
        _walkTargetIdx = 1
    end)
end

function Skills.WeightTrain()
    equipDumbbell()
    task.spawn(function()
        while Flags.WeightTrain do
            equipDumbbell()
            task.wait(2)
        end
    end)
end

function Skills.SpeedUpgrade()
    task.spawn(function()
        while Flags.SpeedUpgrade do
            pcall(function()
                net:WaitForChild("rev_SPEED_UPGRADE"):FireServer(1)
            end)
            task.wait(0.4)
        end
    end)
end

RunService.Heartbeat:Connect(function(dt)
    local char = getChar()
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if Flags.Farm then
        local diff = farmTarget.Position - root.Position
        if diff.Magnitude > 2 then
            root.Velocity = Vector3.zero
            root.CFrame   = root.CFrame + diff.Unit * Flags.WalkSpeed * dt
        end
    end

    if Flags.WeightTrain then
        pcall(function()
            local gui = LP.PlayerGui:FindFirstChild("KickUpgrades")
            if not gui then return end
            local targets = { gui:GetChildren()[4], gui:GetChildren()[5], gui:FindFirstChild("Bonus", true) }
            for _, btn in pairs(targets) do
                if btn and btn.Visible then
                    local click = btn:IsA("ImageButton") and btn or btn:FindFirstChildWhichIsA("ImageButton", true)
                    if click then
                        for _, con in pairs(getconnections(click.Activated))        do con:Fire() end
                        for _, con in pairs(getconnections(click.MouseButton1Click)) do con:Fire() end
                    end
                end
            end
        end)
    end
end)


