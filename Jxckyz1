--- หาเป้าหมายที่ใกล้ที่สุด
local function InRaya(Path, condition)
local ClosestTarget = nil
local ShortestDistance = math.huge
for _, Object in pairs(Path) do
    if condition(Object) then
        local Distance = (Object:GetPivot().Position - RootPart.Position).Magnitude
        if Distance < ShortestDistance then
            ShortestDistance = Distance
            ClosestTarget = Object
        end
    end
end
return ClosestTarget
end

--- รับเควส (ใช้ทั้ง Remote และ FirePrompt)
local function AcceptQuest(questName)
pcall(function()
    -- ใช้ Remote
    local args = {questName}
    ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("QuestAccept"):FireServer(unpack(args))
    
    -- ใช้ FirePrompt
    local questNPC = nil
    if questName == "QuestNPC1" then
        questNPC = Workspace.ServiceNPCs:FindFirstChild("QuestNPC1")
    else
        questNPC = Workspace:FindFirstChild(questName)
    end
    
    if questNPC then
        local prompt = questNPC:FindFirstChild("HumanoidRootPart")
        if prompt then
            prompt = prompt:FindFirstChild("QuestPrompt")
            if prompt then
                fireproximityprompt(prompt)
            end
        end
    end
end)
end

