--- 🎯 AUTO FARM
func['AutoFarm'] = function()
    while task.wait(0.1) do
        xpcall(function()
            if not c().AutoFarm then
                DisableNoClip()
                return
            end

            EnableNoClip()

            if not c().SelectedMob or c().SelectedMob == "" then
                return
            end

            local mob = InRaya(GetAllAI(), function(v)
                local baseName = v.Name:match("^(%a+)") or v.Name
                return baseName == c().SelectedMob
                    and v:FindFirstChild("Humanoid")
                    and v.Humanoid.Health > 0
            end)

            if not mob then
                task.wait(0.5)
                return
            end

            local hrp = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChildWhichIsA("BasePart")
            if not hrp then return end

            repeat
                task.wait()

                local offsetY = c().FarmOffsetY or 4
                Teleport(CFrame.new(hrp.Position - Vector3.new(0, offsetY, 0)) * CFrame.Angles(math.rad(90), 0, 0))

                if c().AutoFastAttack then
                    Attack()
                end
            until not c().AutoFarm
                or not mob.Parent
                or not mob:FindFirstChild("Humanoid")
                or mob.Humanoid.Health <= 0

        end, warn)
    end
end


