-- Config system
local mainFolder = "Zepthic"
local path = mainFolder.."/AC"
local ConfigName = path.."/"..LocalPlayer.Name.."-config.json"

local Settings = {
    Pod = "P1",
    Level = "namek_level_1", 
    Difficulty = "Normal",
    ChallengePod = "ChallengePod1",
    AutoJoinStory = false,
    AutoJoinChallenge = false,
    AutoRetry = false,
    AutoNext = false,
    WhiteScreen = false,
    DiscordEnabled = false,
    DiscordURL = "https://discord.com/api/webhooks/YOUR_WEBHOOK_URL"
}

-- Create folders and load config
pcall(function()
    if not isfolder(mainFolder) then makefolder(mainFolder) end
    if not isfolder(path) then makefolder(path) end
    
    if isfile(ConfigName) then
        local success, result = pcall(function()
            return HttpService:JSONDecode(readfile(ConfigName))
        end)
        if success and type(result) == "table" then
            for key, value in pairs(result) do
                Settings[key] = value
            end
        end
    end
end)

local function SaveConfig()
    pcall(function()
        writefile(ConfigName, HttpService:JSONEncode(Settings))
    end)
end

-- Simple connection manager
local connections = {}

local function CreateConnection(name, func)
    if connections[name] then
        connections[name]:Disconnect()
    end
    connections[name] = RunService.Heartbeat:Connect(func)
end

local function StopConnection(name)
    if connections[name] then
        connections[name]:Disconnect()
        connections[name] = nil
    end
end

-- Game functions
local GameFunctions = {}

GameFunctions.JoinStoryPod = function()
    if Settings.AutoJoinStory then
        CreateConnection("StoryJoin", function()
            if not Settings.AutoJoinStory then
                StopConnection("StoryJoin")
                return
            end
            
            pcall(function()
                if not workspace:FindFirstChild('Map') then
                    -- Join Pod
                    ReplicatedStorage.endpoints.client_to_server.request_join_lobby:InvokeServer(Settings.Pod)
                    wait(2)
                    
                    -- Lock Level
                    ReplicatedStorage.endpoints.client_to_server.request_lock_level:InvokeServer(
                        Settings.Pod, Settings.Level, false, Settings.Difficulty
                    )
                    wait(2)
                    
                    -- Start Game
                    ReplicatedStorage.endpoints.client_to_server.request_start_game:InvokeServer(Settings.Pod)
                    wait(5)
                end
            end)
            wait(3)
        end)
    else
        StopConnection("StoryJoin")
    end
end

GameFunctions.JoinChallenge = function()
    if Settings.AutoJoinChallenge then
        CreateConnection("ChallengeJoin", function()
            if not Settings.AutoJoinChallenge then
                StopConnection("ChallengeJoin")
                return
            end
            
            pcall(function()
                if not workspace:FindFirstChild('Map') then
                    -- Join Challenge
                    ReplicatedStorage.endpoints.client_to_server.request_join_lobby:InvokeServer(Settings.ChallengePod)
                    wait(2)
                    
                    -- Start Challenge
                    ReplicatedStorage.endpoints.client_to_server.request_start_game:InvokeServer(Settings.ChallengePod)
                    wait(5)
                end
            end)
            wait(3)
        end)
    else
        StopConnection("ChallengeJoin")
    end
end

GameFunctions.AutoRetry = function()
    if Settings.AutoRetry then
        CreateConnection("AutoRetry", function()
            if not Settings.AutoRetry then
                StopConnection("AutoRetry")
                return
            end
            
            pcall(function()
                ReplicatedStorage.endpoints.client_to_server.set_game_finished_vote:InvokeServer("replay")
            end)
            wait(2)
        end)
    else
        StopConnection("AutoRetry")
    end
end

GameFunctions.AutoNext = function()
    if Settings.AutoNext then
        CreateConnection("AutoNext", function()
            if not Settings.AutoNext then
                StopConnection("AutoNext")
                return
            end
            
            pcall(function()
                ReplicatedStorage.endpoints.client_to_server.set_game_finished_vote:InvokeServer("Next Story")
            end)
            wait(2)
        end)
    else
        StopConnection("AutoNext")
    end
end

GameFunctions.WhiteScreen = function()
    if Settings.WhiteScreen then
        RunService:Set3dRenderingEnabled(false)
    else
        RunService:Set3dRenderingEnabled(true)
    end
end

