Tabs.AutoJoin:AddButton({
    Title = "Check Remotes",
    Description = "Verify if game remotes exist",
    Callback = function()
        local status = {}
        
        pcall(function()
            if ReplicatedStorage:FindFirstChild("endpoints") then
                table.insert(status, "✅ endpoints found")
                
                if ReplicatedStorage.endpoints:FindFirstChild("client_to_server") then
                    table.insert(status, "✅ client_to_server found")
                    
                    local cts = ReplicatedStorage.endpoints.client_to_server
                    local remotes = {"request_join_lobby", "request_lock_level", "request_start_game", "set_game_finished_vote"}
                    
                    for _, remote in ipairs(remotes) do
                        if cts:FindFirstChild(remote) then
                            table.insert(status, "✅ " .. remote .. " found")
                        else
                            table.insert(status, "❌ " .. remote .. " NOT found")
                        end
                    end
                else
                    table.insert(status, "❌ client_to_server NOT found")
                end
            else
                table.insert(status, "❌ endpoints NOT found")
            end
        end)
        
        Fluent:Notify({
            Title = "Remote Check",
            Content = table.concat(status, "\n"),
            Duration = 8
        })
    end
})

