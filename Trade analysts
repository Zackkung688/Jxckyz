-- Trade System Logic
local function updateStatus(text)
    statusLabel.Text = "Status: "..text
    print("[Auto Trade] "..text)
end

local function sendTradeRequest()
    if not selectedPlayer then
        updateStatus("❌ Please select a player first!")
        return
    end
    
    local args = {selectedPlayer}
    TradeSystem.SendTradeRequest:FireServer(unpack(args))
    updateStatus("✉️ Trade request sent to "..selectedPlayer.Name)
end

local function addItems()
    if not autoAddItems then return end
    
    task.wait(0.5)
    for itemName, _ in pairs(selectedItems) do
        -- ดึงจำนวนจริงจาก InvData
        local invItem = player.InvData:FindFirstChild(itemName)
        if invItem and invItem:IsA("NumberValue") then
            local amount = invItem.Value
            if amount > 0 then
                local args = {"Add", itemName, amount}
                TradeSystem.TradeAction:FireServer(unpack(args))
                updateStatus("➕ Adding "..amount.."x "..itemName)
                task.wait(0.15)
            end
        end
    end
    updateStatus("✅ All items added to trade")
    
    if autoReady then
        task.wait(0.5)
        local args = {"Ready"}
        TradeSystem.TradeAction:FireServer(unpack(args))
        updateStatus("✅ Auto ready activated")
    end
end

local function removeAllItems()
    updateStatus("🗑️ Removing all items...")
    for itemName, _ in pairs(selectedItems) do
        -- ดึงจำนวนจริงจาก InvData
        local invItem = player.InvData:FindFirstChild(itemName)
        if invItem and invItem:IsA("NumberValue") then
            local args = {"Remove", itemName}
            InventoryRemote:InvokeServer(unpack(args))
            updateStatus("➖ Removed "..itemName)
            task.wait(0.1)
        end
    end
    updateStatus("✅ All items removed")
end

local function rejoinServer()
    if getgenv().Rejoined then return end
    getgenv().Rejoined = true
    
    updateStatus("🔄 Rejoining server...")
    local placeId = game.PlaceId
    local jobId = game.JobId
    
    -- เตะตัวเองออกจากเกม (Disconnect)
    player:Kick("🔄 Rejoining to the same server...")
    
    task.wait(1)
    
    -- Teleport กลับเซิร์ฟเวอร์เดิม
    TeleportService:TeleportToPlaceInstance(placeId, jobId, player)
end

-- Auto Accept Trade Requests
