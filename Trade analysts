    if autoAcceptTrade then
        updateStatus("✅ Auto accepted trade from "..fromPlayer.Name)
        addItems()
    end
end)

-- Monitor Countdown
local function monitorCountdown()
    local mainGui = player.PlayerGui:WaitForChild("MainGui")
    local tradingFrame = mainGui:WaitForChild("ONTRADING")
    local countdownLabel = tradingFrame:WaitForChild("CountDown")
    
    countdownLabel:GetPropertyChangedSignal("Text"):Connect(function()
        local text = countdownLabel.Text
        if text ~= "" then
            local num = tonumber(text)
            if num then
                countdownValue = num
                updateStatus("⏱️ Countdown: "..num)
                
                -- เมื่อ countdown = 0.5 ให้ Remove Items
                if num <= 0.5 and num > 0 and autoRemoveAndRejoin and isTrading then
                    removeAllItems()
                end
                
                -- เมื่อ countdown = 0 ให้ Rejoin
                if num == 0 and autoRemoveAndRejoin and isTrading then
                    task.wait(0.3)
                    rejoinServer()
                end
            end
        end
    end)
end

-- เริ่มต้น monitor countdown
pcall(monitorCountdown)

-- Trade Update Handler
TradeSystem.TradeUpdate.OnClientEvent:Connect(function(data)
    if data.countdown then
        countdownValue = data.countdown
    end
end)

-- Trade Complete Handler
TradeSystem.TradeComplete.OnClientEvent:Connect(function(success)
    if success then
        updateStatus("✅ Trade completed successfully!")
    else
        updateStatus("❌ Trade was cancelled")
    end
    isTrading = false
    countdownValue = 0
end)

