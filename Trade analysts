local function updateItemList()
    for _, child in pairs(itemList:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    local yPos = 0
    
    -- วนลูปผ่าน InvData และเรียงตามชื่อ
    local items = {}
    for _, itemValue in pairs(player.InvData:GetChildren()) do
        if itemValue:IsA("NumberValue") and itemValue.Value > 0 then
            table.insert(items, {name = itemValue.Name, value = itemValue.Value})
        end
    end
    
    -- เรียงตามชื่อ
    table.sort(items, function(a, b)
        -- ถ้าเป็นตัวเลข ให้เรียงตามตัวเลข
        local aNum = tonumber(a.name)
        local bNum = tonumber(b.name)
        if aNum and bNum then
            return aNum < bNum
        end
        return a.name < b.name
    end)
    
    for _, item in ipairs(items) do
        local itemName = item.name
        local itemAmount = item.value
        
        -- แสดงชื่อให้สวยงาม
        local displayName = itemName
        if tonumber(itemName) then
            displayName = "Item #"..itemName
        end
        
        local itemFrame = createFrame(itemName.."Frame", itemList, UDim2.new(1, -10, 0, 35), UDim2.new(0, 0, 0, yPos), Color3.fromRGB(45, 45, 55))
        
        local label = createTextLabel("Label", itemFrame, UDim2.new(0.6, 0, 1, 0), UDim2.new(0, 10, 0, 0), displayName.." ["..itemAmount.."]")
        
        local toggle = Instance.new("TextButton")
        toggle.Size = UDim2.new(0, 50, 0, 25)
        toggle.Position = UDim2.new(1, -60, 0.5, -12)
        toggle.BackgroundColor3 = selectedItems[itemName] and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
        toggle.Text = selectedItems[itemName] and "ON" or "OFF"
        toggle.TextColor3 = Color3.new(1, 1, 1)
        toggle.TextSize = 12
        toggle.Font = Enum.Font.GothamBold
        toggle.BorderSizePixel = 0
        toggle.Parent = itemFrame
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 4)
        corner.Parent = toggle
        
        toggle.MouseButton1Click:Connect(function()
            if selectedItems[itemName] then
                selectedItems[itemName] = nil
                toggle.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                toggle.Text = "OFF"
            else
                selectedItems[itemName] = true
                toggle.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
                toggle.Text = "ON"
            end
        end)
        
        yPos = yPos + 40
    end
    
    itemList.CanvasSize = UDim2.new(0, 0, 0, yPos)
end

